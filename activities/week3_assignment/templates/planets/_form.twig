{% if planet is defined %}
    <form
    enctype="multipart/form-data"
    action="/planets/{{ planet.id }}"
    method="POST">
        <input type="hidden" name="id" value="{{ planet.id }}" />
{% else %}
    <form enctype="multipart/form-data" action="/planets" method="POST">
{% endif %}

    <div class="control">
        <label>Name:</label>
        <input
            type="text"
            name="planetName"
            required
            {% if planet is defined %}
                value="{{ planet.planetName }}"
            {% endif %}
        />
    </div>

    <div class="control">
        <label>Size:</label>
        <input
            type="number"
            name="planetSize"
            min="1"
            step="1"
            required
            {% if planet is defined %}
                value="{{ planet.planetSize }}"
            {% endif %}
        />
    </div>

    <div class="control">
        <label>Description:</label>
        <textarea
            name="planetDescription"
            rows="4"
        >{{ planet.planetDescription }}</textarea>
    </div>

    <div class="control">
        <label>Galaxy:</label>
        <select
            name="GalaxyId"
            id="galaxyId"
            required>
            <option value="" disabled {% if selectedGalaxyId is not defined %}selected{% endif %}>Select a Parent Galaxy</option>
            <option disabled>---</option>
            {% for galaxy in galaxies %}
                <option
                    {% if selectedGalaxyId == galaxy.id %}
                        selected
                    {% endif %}
                    value="{{ galaxy.id }}">
                        {{ galaxy.galaxyName }}
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="control">
        <label>Stars (hold CMD/CTRL for multi-select):</label>
        <select
            name="StarIds"
            id="starId"
            multiple
            size="7"
            required
            disabled>
            {% for star in stars %}
                <option
                    {% if selectedStarIds is defined and star.id in selectedStarIds %}
                        selected
                    {% endif %}
                    value="{{ star.id }}">
                        {{ star.starName }}
                </option>
            {% endfor %}
        </select>
    </div>

    <div class="control">
        <label>Image:</label>
        <input type="file" name="image" id="image" accept="image/*" />
    </div>

    <button type="submit">
        {% if planet is defined %}
            Update Planet
        {% else %}
            Add Planet
        {% endif %}
    </button>

</form>

<script>
    const galaxyDropdown = document.querySelector('#galaxyId')
    const starDropdown = document.querySelector('#starId')
    const selectedStarIds = {{ selectedStarIds is defined ? selectedStarIds|json_encode|raw : '[]' }}
    const stars = {{ stars is defined ? stars|json_encode|raw : '[]' }}

    galaxyDropdown.addEventListener('change', handleChangeGalaxy)

    function handleChangeGalaxy(e) {
        if(e.target == galaxyDropdown) {
            repopulateStars([])
        }
    }

    // AI assisted: rebuild star options from selected galaxy and apply multi-selections.
    function repopulateStars(idsToSelect) {
        starDropdown.innerHTML = ""
        const matchingStars = []
        stars.forEach(star => {
            if(star.dataValues.GalaxyId == galaxyDropdown.value) {
                matchingStars.push(star.dataValues)
            }
        })
        starDropdown.disabled = matchingStars.length == 0
        
        matchingStars.forEach(star => {
            const newStarOption = document.createElement("option");
            newStarOption.value = star.id
            if (idsToSelect.includes(star.id)) newStarOption.selected = true
            newStarOption.innerHTML = star.starName
            starDropdown.appendChild(newStarOption)
        })
    }

    repopulateStars(selectedStarIds) // Run on load
</script>
